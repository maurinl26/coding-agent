# Dockerfile for the Fortran-to-JAX LangGraph Agents
FROM python:3.11-slim

# Install system dependencies (gfortran for compilation/testing)
RUN apt-get update && apt-get install -y \
    build-essential \
    gfortran \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip

# Install Loki-IFS
RUN git clone https://github.com/ecmwf-ifs/loki.git /opt/loki && \
    cd /opt/loki && pip install -e .

# Install JAX (CPU version by default for CI runners, or switch to jax[cuda12] if using GPU runners)
RUN pip install --no-cache-dir jax[cpu] numpy pytest

# Install Agent dependencies
COPY local_code_agent/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY . .

ENV PYTHONPATH=/app
